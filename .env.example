# Скопируйте в `.env` и при необходимости поправьте значения.
# Docker Compose подхватывает переменные из `.env` в корне проекта.

###> docker compose / mysql ###
MYSQL_DATABASE=fartest26
MYSQL_USER=app
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme_root
###< docker compose / mysql ###

###> doctrine/doctrine-bundle ###
# Для консоли Symfony на хосте (вне Docker) — логин/пароль как в MYSQL_*.
DATABASE_URL="mysql://app:changeme@127.0.0.1:3306/fartest26?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
